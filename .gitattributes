# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly LF for source files
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.ipynb text eol=lf
*.csv   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.pt    binary
*.pth   binary
*.ckpt  binary
*.zip   binary
*.tar.gz binary
